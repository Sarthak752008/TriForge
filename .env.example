# =========================================================
# TriForge Environment Configuration
# Copy this file to .env and fill in your values
# =========================================================

# ---- REQUIRED ----
# Groq API Key (FREE) — used as the "local" model provider
# Sign up at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
# PostgreSQL Database URL — used in production
# Free option: Sign up at https://neon.tech → Create project → Copy connection string
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@host/triforge?sslmode=require

# ---- OPTIONAL Remote Providers ----
# If not set, Groq (llama-3.3-70b-versatile) is used as remote model too

# Fireworks AI API Credentials
# FIREWORKS_API_KEY=your_fireworks_api_key_here

# OpenAI API Credentials
# OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Credentials
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ---- MODEL SETTINGS ----
# Local model (Groq free models): llama-3.1-8b-instant, gemma2-9b-it, mixtral-8x7b-32768
ACTIVE_LOCAL_MODEL=llama-3.1-8b-instant

# Remote model: llama-3.3-70b-versatile (Groq), or accounts/fireworks/models/llama-v3p1-70b-instruct
ACTIVE_REMOTE_MODEL=llama-3.3-70b-versatile

# ---- ROUTING SETTINGS ----
DEFAULT_CONSISTENCY_THRESHOLD=0.8
ENABLE_CACHE=true
ENABLE_PROMPT_COMPRESSION=false

# ---- LOCAL DEV ONLY ----
# Only needed if running Ollama locally (not needed for cloud deployment)
# OLLAMA_BASE_URL=http://localhost:11434

# ---- LOCAL DEV SQLITE (optional) ----
# Use this for local dev without setting up PostgreSQL
# DATABASE_URL=sqlite:///./triforge.db
